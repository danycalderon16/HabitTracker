{
  "expo": {
    "name": "HabitTracker",
    "slug": "HabitTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "habittracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.danycalderon16.HabitTracker"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
